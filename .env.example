# MongoDB Connection
MONGODB_URI=mongodb+srv://your_user:your_password@cluster0.example.mongodb.net/cricket_management

# Main admin (cannot be deleted from Settings — stored in .env only)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_secure_password

# Or use JSON (first entry = main admin shown in Settings)
# ADMIN_CREDENTIALS=[{"email":"admin@example.com","password":"your_secure_password"}]

# JWT Secret (generate a strong random string for production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# App
NEXT_PUBLIC_APP_NAME=Cricketer Management System
PORT=3000

# Public registration branding (Gujarati — shown on registration form, PDF, success screen)
NEXT_PUBLIC_ORGANIZATION_NAME_GU=ઢુંઢીયા પીપળીયા
NEXT_PUBLIC_TOURNAMENT_YEAR=2026
# Regenerate Gujarati branding: node scripts/write-env-gujarati.js
# NEXT_PUBLIC_TOURNAMENT_TITLE_GU=
